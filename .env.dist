# ==========================================================================
# Project Benjamin SRE Agentic Environment Configuration Template (.env.dist)
# Copy this file to '.env' and fill in your custom operational keys.
# ==========================================================================

# SRE execution mode settings (Set MOCK_TOOLING to false to enable live GCP resource checks)
MOCK_TOOLING=false
DISCOVERY_FIRST=true

# SRE default Gemini model configuration coordinate
DEFAULT_GEMINI_MODEL="gemini-3.1-flash-lite"

# Functional SRE leads custom renaming config
COMMS_LEAD_NAME="Raffaealla Karra"
COMMANDER_NAME="Ben Treno"
OPS_LEAD_NAME="Gigi Mutatore"
SCRIBE_LEAD_NAME="ScrIvano Di Martino"
LOGISTIC_LEAD_NAME="Talete Diotisalvi"

# GCP SRE Least-Privilege secure Service Account impersonation details
GCP_SERVICE_ACCOUNT="safe-sre-investigator@sre-next.iam.gserviceaccount.com"
GOOGLE_IMPERSONATE_SERVICE_ACCOUNT="safe-sre-investigator@sre-next.iam.gserviceaccount.com"
GCP_PROJECT_ID="sre-next"

# ==========================================================================
# Telegram Alerts Integration Config
# ==========================================================================
# Obtain your token by messaging @BotFather on Telegram (run /newbot)
TELEGRAM_BOT_TOKEN="ENTER_BOT_TOKEN_HERE"

# Retrieve your user ID or channel ID by messaging @GetIdsBot or @userinfobot
TELEGRAM_CHAT_ID="ENTER_CHAT_ID_HERE"
