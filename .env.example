# Project Benjamin SRE Agentic Environment Configuration

# SRE Execution Mode: [MOCK / LIVE]
# LIVE mode runs real-time queries against GCP services.
SRE_MODE=LIVE

# SRE default Gemini model configuration coordinate
DEFAULT_GEMINI_MODEL=gemini-3.1-flash-lite

# Telegram Bot Integration (Optional)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# GCP Configuration (Required for LIVE mode)
GCP_PROJECT_ID=prod-db-999
GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json
