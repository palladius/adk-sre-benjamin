# Project Benjamin SRE Agentic Environment Configuration

# SRE Execution Mode: [MOCK / LIVE]
# MOCK mode runs lightning-fast, zero-dependency local diagnostic queries.
SRE_MODE=MOCK

# Telegram Bot Integration (Optional)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# GCP Configuration (Required for LIVE mode)
GCP_PROJECT_ID=prod-db-999
GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json
